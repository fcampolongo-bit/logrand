config { type: "operations" }

SELECT
    Sala,
    GameDay,
    Num_Cliente,
    Puntos_Asignados,
    Drop,
    Pagos,
    Win_Mesas,
    TiempoDeJuego,
    Visitas
FROM ${ref("TBL_CLIENTES_MESAS_GLD")}
WHERE Sala = 'DUBAI'
  AND GameDay = '2020-01-02'
  AND Num_Cliente IN (1202093, 1220093, 1556093, 1953093, 1985093)
ORDER BY Num_Cliente