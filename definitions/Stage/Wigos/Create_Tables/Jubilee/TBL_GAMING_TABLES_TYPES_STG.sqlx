config {
  type: "table",
  schema: "STG_WIGOS_JUBILEE",
  name: "TBL_GAMING_TABLES_TYPES_STG",
  bigquery: {
    clusterBy: ["gtt_gaming_table_type_id"]
  }
}

SELECT
  gtt_gaming_table_type_id,
  gtt_name,
  gtt_enabled,
  gtt_report_type_id,
  CURRENT_TIMESTAMP() AS ingestion_ts
FROM
  `logrand-storage-raw-dev.RAW_WIGOS_JUBILEE.TBL_GAMING_TABLES_TYPES_RAW`
