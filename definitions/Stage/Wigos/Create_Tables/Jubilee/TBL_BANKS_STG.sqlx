config {
  type: "table",
  schema: "STG_WIGOS_JUBILEE",
  name: "TBL_BANKS_STG",
  bigquery: {
    partitionBy: "DATE(bk_timestamp)",
    clusterBy: ["bk_bank_id"]
  }
}

SELECT
  bk_bank_id,
  bk_area_id,
  bk_name,
  bk_timestamp,
  bk_multiposition,
  bk_external_id,
  CURRENT_TIMESTAMP() AS ingestion_ts
FROM
  `logrand-computo-dev.RAW_WIGOS_JUBILEE.TBL_BANKS_RAW`